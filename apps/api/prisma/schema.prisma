generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

enum DealStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  SOLD
  RENTED
  UNDER_MAINTENANCE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  SUSPENDED
}

enum ContractType {
  SALE
  LEASE
  RENTAL
}

enum ContractStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  EXPIRED
  TERMINATED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  PARTIAL
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  CREDIT_CARD
  ONLINE
}

enum DepositStatus {
  HELD
  APPLIED
  REFUNDED
  FORFEITED
}

enum MeterType {
  ELECTRICITY
  WATER
  GAS
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatusEnum {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum HandoverType {
  INITIAL
  FINAL
  PARTIAL
}

enum HandoverStatus {
  PENDING
  COMPLETED
  REJECTED
}

enum InspectionStatus {
  PASS
  FAIL
  CONDITIONAL
}

enum DocumentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  SUPERSEDED
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum MeetingStatus {
  DRAFT
  FINALIZED
  DISTRIBUTED
}

enum UpdateRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WarehouseRequirementStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  APPROVED
  REJECTED
}

enum SaleJobStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum AssetStatus {
  OPERATIONAL
  UNDER_MAINTENANCE
  OUT_OF_SERVICE
  DISPOSED
  IN_STORAGE
}

enum WorkOrderStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum WorkOrderType {
  CORRECTIVE
  PREVENTIVE
  EMERGENCY
  INSPECTION
  CALIBRATION
}

enum PMFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  CUSTOM
}

enum CalibrationStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
  OVERDUE
}

enum PatrolStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  MISSED
}

enum VisitorStatus {
  EXPECTED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum PettyCashStatus {
  PENDING
  APPROVED
  REJECTED
  SETTLED
}

enum StockMovementType {
  RECEIVED
  ISSUED
  RETURNED
  ADJUSTED
  TRANSFERRED
}

enum GRNStatus {
  DRAFT
  RECEIVED
  INSPECTED
  ACCEPTED
  REJECTED
}

enum PRStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  CONVERTED
}

enum POStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
  CLOSED
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
  PENDING_APPROVAL
}

enum VendorContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum BudgetStatus {
  DRAFT
  APPROVED
  ACTIVE
  CLOSED
}

enum PermitStatus {
  DRAFT
  SUBMITTED
  APPROVED
  ACTIVE
  CLOSED
  REJECTED
}

enum IncidentSeverity {
  MINOR
  MODERATE
  MAJOR
  CRITICAL
}

enum IncidentStatus {
  REPORTED
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum InsurancePolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING_RENEWAL
}

enum DisasterPlanType {
  FIRE
  EARTHQUAKE
  FLOOD
  CHEMICAL
  OTHER
}

enum DisasterPlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DrillStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Auth Domain ──────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  first_name    String
  last_name     String
  avatar_url    String?
  phone         String?
  department    String?
  position      String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  refresh_tokens         RefreshToken[]
  roles                  UserRole[]
  audit_logs             UserAuditLog[]
  assigned_leads         Lead[]                  @relation("LeadAssignee")
  assigned_deals         Deal[]                  @relation("DealAssignee")
  approved_quotations    Quotation[]             @relation("QuotationApprover")
  created_quotations     Quotation[]             @relation("QuotationCreator")
  created_commercial_quotations CommercialQuotation[] @relation("CommercialQuotationCreator")
  created_commercial_proposals  CommercialProposal[]  @relation("CommercialProposalCreator")
  approved_contracts     Contract[]              @relation("ContractApprover")
  created_contracts      Contract[]              @relation("ContractCreator")
  handed_handovers       Handover[]              @relation("HandoverHandedBy")
  created_invoices       Invoice[]               @relation("InvoiceCreator")
  received_payments      Payment[]               @relation("PaymentReceiver")
  assigned_tasks         Task[]                  @relation("TaskAssignee")
  created_tasks          Task[]                  @relation("TaskCreator")
  task_comments          TaskComment[]
  assigned_tickets       Ticket[]                @relation("TicketAssignee")
  requested_tickets      Ticket[]                @relation("TicketRequester")
  uploaded_documents     Document[]              @relation("DocumentUploader")
  approved_iso_documents ISODocument[]           @relation("ISODocumentApprover")
  created_meeting_minutes MeetingMinute[]        @relation("MeetingMinuteCreator")
  notifications          Notification[]
  notification_preferences NotificationPreference[]
  activity_logs          ActivityLog[]
  comments               Comment[]
  reviewed_update_requests ClientUpdateRequest[] @relation("UpdateRequestReviewer")
  created_warehouse_requirements WarehouseRequirement[] @relation("WarehouseRequirementCreator")
  created_sale_job04f01  SaleJob04F01[]          @relation("SaleJobCreator")
  approved_sale_job04f01 SaleJob04F01[]          @relation("SaleJobApprover")
  assigned_assets        Asset[]                 @relation("AssetAssignee")
  assigned_work_orders   WorkOrder[]             @relation("WorkOrderAssignee")
  created_work_orders    WorkOrder[]             @relation("WorkOrderCreator")
  assigned_pms           PreventiveMaintenance[] @relation("PMAssignee")
  created_pms            PreventiveMaintenance[] @relation("PMCreator")
  completed_pm_logs      PMScheduleLog[]         @relation("PMLogCompleter")
  created_service_logs   ServiceLog[]            @relation("ServiceLogCreator")
  petty_cash_funds       PettyCashFund[]         @relation("PettyCashCustodian")
  petty_cash_requested   PettyCashTransaction[]  @relation("PettyCashRequester")
  petty_cash_approved    PettyCashTransaction[]  @relation("PettyCashApprover")
  stock_movements        StockMovement[]         @relation("StockMovementPerformer")
  stock_issues_to        StockIssue[]            @relation("StockIssueTo")
  stock_issues_by        StockIssue[]            @relation("StockIssueBy")
  stock_transfers_by     StockTransfer[]         @relation("StockTransferBy")
  grn_received           GoodsReceivedNote[]     @relation("GRNReceiver")
  pr_requested           PurchaseRequest[]       @relation("PRRequester")
  pr_approved            PurchaseRequest[]       @relation("PRApprover")
  po_created             PurchaseOrder[]         @relation("POCreator")
  po_approved            PurchaseOrder[]         @relation("POApprover")
  budgets_created        Budget[]                @relation("BudgetCreator")
  budgets_approved       Budget[]                @relation("BudgetApprover")
  budget_transactions    BudgetTransaction[]     @relation("BudgetTransactionCreator")
  requested_permits      PermitToWork[]          @relation("PTWRequester")
  approved_permits       PermitToWork[]          @relation("PTWApprover")
  reported_incidents     Incident[]              @relation("IncidentReporter")
  approval_requests      ApprovalRequest[]       @relation("ApprovalRequester")
  journal_entries_prepared  JournalEntry[]       @relation("JEPreparer")
  journal_entries_reviewed  JournalEntry[]       @relation("JEReviewer")
  journal_entries_approved  JournalEntry[]       @relation("JEApprover")
  accounting_periods_closed AccountingPeriod[]   @relation("PeriodCloser")
  reconciliations_done     BankReconciliation[] @relation("ReconciliationReconciler")
  wht_created              WithholdingTaxRecord[] @relation("WHTCreator")
  ap_invoices_created      APInvoice[]          @relation("APInvoiceCreator")
  ap_invoices_approved     APInvoice[]          @relation("APInvoiceApprover")
  payment_vouchers_created PaymentVoucher[]     @relation("PVCreator")
  payment_vouchers_approved PaymentVoucher[]    @relation("PVApprover")
  asset_disposals_created  AssetDisposal[]      @relation("DisposalCreator")
  asset_transfers_created  AssetTransfer[]      @relation("TransferCreator")

  @@index([email])
}

model Role {
  id             String   @id @default(uuid())
  name           String   @unique
  code           String?  @unique
  description    String?
  permissions    Json     @default("{}")
  is_system_role Boolean  @default(false)
  created_at     DateTime @default(now())

  user_roles UserRole[]
}

model UserRole {
  user_id    String
  role_id    String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
  @@index([user_id])
  @@index([role_id])
}

model UserAuditLog {
  id         String   @id @default(uuid())
  user_id    String
  action     String
  details    Json?
  ip_address String?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([created_at])
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token])
}

// ─── CRM Domain ───────────────────────────────────────────────────────────────

model Customer {
  id                    String         @id @default(uuid())
  name                  String
  email                 String?
  phone                 String?
  address               String?
  tax_id                String?
  type                  CustomerType   @default(INDIVIDUAL)
  status                CustomerStatus @default(ACTIVE)
  notes                 String?
  line_id               String?
  province              String?
  lead_source           String?
  industry              String?
  company_size          String?
  budget_range          String?
  deposit_conditions    String?
  profile_url           String?
  pdpa_consent          Boolean        @default(false)
  interested_project_id String?
  created_at            DateTime       @default(now())
  updated_at            DateTime       @updatedAt

  interested_project         Project?              @relation("CustomerInterestedProject", fields: [interested_project_id], references: [id])
  contacts                   Contact[]
  leads                      Lead[]
  deals                      Deal[]
  quotations                 Quotation[]
  commercial_quotations      CommercialQuotation[]
  commercial_proposals       CommercialProposal[]
  contracts                  Contract[]
  invoices                   Invoice[]
  deposits                   Deposit[]
  tickets                    Ticket[]
  warehouse_requirements     WarehouseRequirement[]
  sale_job04f01              SaleJob04F01[]
  client_users               ClientUser[]

  @@index([email])
  @@index([status])
  @@index([type])
  @@index([interested_project_id])
}

model Contact {
  id          String   @id @default(uuid())
  customer_id String
  first_name  String
  last_name   String
  email       String?
  phone       String?
  position    String?
  is_primary        Boolean  @default(false)
  line_id           String?
  is_decision_maker Boolean  @default(false)
  created_at        DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  leads    Lead[]

  @@index([customer_id])
  @@index([email])
}

model Company {
  id                  String   @id @default(uuid())
  name                String
  tax_id              String?
  address             String?
  phone               String?
  email               String?
  website             String?
  industry            String?
  status              String   @default("ACTIVE")
  notes               String?
  sales_contact_name  String?
  sales_contact_phone String?
  sales_contact_email String?
  logo_url            String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([email])
  @@index([status])
}

// ─── Sales Domain ─────────────────────────────────────────────────────────────

model Lead {
  id                  String     @id @default(uuid())
  title               String
  customer_id         String?
  contact_id          String?
  source              String?
  status              LeadStatus @default(NEW)
  value               Float?
  probability         Int?
  expected_close_date DateTime?
  notes               String?
  assigned_to         String?
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  customer Customer? @relation(fields: [customer_id], references: [id])
  contact  Contact?  @relation(fields: [contact_id], references: [id])
  assignee User?     @relation("LeadAssignee", fields: [assigned_to], references: [id])
  deals    Deal[]

  @@index([customer_id])
  @@index([contact_id])
  @@index([assigned_to])
  @@index([status])
}

model Deal {
  id                  String    @id @default(uuid())
  title               String
  customer_id         String?
  lead_id             String?
  stage               DealStage @default(PROSPECTING)
  value               Float?
  probability         Int?
  expected_close_date DateTime?
  actual_close_date   DateTime?
  notes               String?
  assigned_to         String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  customer Customer? @relation(fields: [customer_id], references: [id])
  lead     Lead?     @relation(fields: [lead_id], references: [id])
  assignee User?     @relation("DealAssignee", fields: [assigned_to], references: [id])

  @@index([customer_id])
  @@index([lead_id])
  @@index([assigned_to])
  @@index([stage])
}

// ─── Property Domain ──────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(uuid())
  name        String
  code        String        @unique
  description String?
  address     String?
  type        String
  status      ProjectStatus @default(ACTIVE)
  total_units Int           @default(0)
  settings    Json          @default("{}")
  is_site     Boolean       @default(false)
  site_type   String?
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  interested_customers       Customer[]             @relation("CustomerInterestedProject")
  units                      Unit[]
  zones                      Zone[]
  quotations                 Quotation[]
  commercial_quotations      CommercialQuotation[]
  commercial_proposals       CommercialProposal[]
  contracts                  Contract[]
  tasks                      Task[]
  warehouse_requirements     WarehouseRequirement[]
  sale_job04f01              SaleJob04F01[]
  assets                     Asset[]
  work_orders                WorkOrder[]
  preventive_maintenances    PreventiveMaintenance[]
  security_patrols           SecurityPatrol[]
  cleaning_checklists        CleaningChecklist[]
  visitors                   Visitor[]
  key_records                KeyRecord[]
  parking_slots              ParkingSlot[]
  service_logs               ServiceLog[]
  petty_cash_funds           PettyCashFund[]
  petty_cash_transactions    PettyCashTransaction[]
  inventory_items            InventoryItem[]
  stock_issues               StockIssue[]
  stock_transfers_source     StockTransfer[]     @relation("StockTransferSource")
  stock_transfers_destination StockTransfer[]    @relation("StockTransferDestination")
  goods_received_notes       GoodsReceivedNote[]
  purchase_requests          PurchaseRequest[]
  purchase_orders            PurchaseOrder[]
  vendor_contracts           VendorContract[]
  budgets                    Budget[]
  fire_equipment             FireEquipment[]
  permits_to_work            PermitToWork[]
  incidents                  Incident[]
  insurance_policies         InsurancePolicy[]
  contractor_safety_records  ContractorSafety[]
  disaster_plans             DisasterPlan[]
  emergency_drills           EmergencyDrill[]
  tickets                    Ticket[]
  fms_meter_records          FmsMeterRecord[]
  utility_rates              UtilityRate[]
  landscape_tasks            LandscapeTask[]
  waste_records              WasteRecord[]
  bank_accounts              BankAccount[]    @relation("BankAccountSite")

  @@index([status])
  @@index([code])
}

model Zone {
  id             String   @id @default(uuid())
  project_id     String
  project        Project  @relation(fields: [project_id], references: [id])
  name           String
  code           String
  description    String?
  floor          String?
  building       String?
  parent_zone_id String?
  parent_zone    Zone?    @relation("ZoneHierarchy", fields: [parent_zone_id], references: [id])
  children       Zone[]   @relation("ZoneHierarchy")
  units          Unit[]
  assets         Asset[]
  work_orders    WorkOrder[]
  preventive_maintenances PreventiveMaintenance[]
  cleaning_checklists CleaningChecklist[]
  key_records    KeyRecord[]
  parking_slots  ParkingSlot[]
  fire_equipment         FireEquipment[]
  permits_to_work        PermitToWork[]
  incidents              Incident[]
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@unique([project_id, code])
  @@index([project_id])
  @@index([parent_zone_id])
}

model ProjectTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  settings    Json     @default("{}")
  created_at  DateTime @default(now())
}

model Unit {
  id          String     @id @default(uuid())
  project_id  String
  unit_number String
  floor       Int?
  building    String?
  type        String
  area_sqm    Float?
  price       Float?
  status      UnitStatus @default(AVAILABLE)
  features    Json       @default("{}")
  zone_legacy             String?
  zone_id                 String?
  location                String?
  office_area_sqm         Float?
  floor_load              String?
  electrical_load         String?
  ceiling_height          Float?
  lease_type              String?
  floor_plan_url          String?
  has_sprinkler           Boolean  @default(false)
  rent_per_sqm            Float?
  common_fee              Float?
  common_fee_waived       Boolean  @default(false)
  water_rate              Float?
  water_rate_actual       Boolean  @default(false)
  electricity_rate        Float?
  electricity_rate_actual Boolean  @default(false)
  deposit_months          Int?
  advance_rent_months     Int?
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  project      Project       @relation(fields: [project_id], references: [id])
  zone         Zone?         @relation(fields: [zone_id], references: [id])
  quotations   Quotation[]
  contracts    Contract[]
  meter_records MeterRecord[]
  tickets      Ticket[]
  sale_job04f01 SaleJob04F01[]
  assets       Asset[]
  work_orders  WorkOrder[]
  visitors     Visitor[]     @relation("VisitorUnit")
  key_records  KeyRecord[]   @relation("KeyRecordUnit")
  parking_slots ParkingSlot[] @relation("ParkingUnit")

  @@index([project_id])
  @@index([status])
  @@unique([project_id, unit_number])
}

// ─── Sales Documents Domain ───────────────────────────────────────────────────

model Quotation {
  id               String          @id @default(uuid())
  quotation_number String          @unique
  customer_id      String
  project_id       String
  unit_id          String?
  items            Json            @default("[]")
  total_amount     Float           @default(0)
  discount         Float           @default(0)
  tax              Float           @default(0)
  grand_total      Float           @default(0)
  status                QuotationStatus @default(DRAFT)
  valid_until           DateTime?
  notes                 String?
  approved_by           String?
  created_by            String
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  deposit_months        Int?
  advance_rent_months   Int?
  electricity_rate_type String?
  electricity_rate      Float?
  water_rate            Float?
  deposit_decoration    String?
  registration_fee      String?
  property_tax          String?
  building_insurance    String?
  goods_insurance       String?
  special_conditions    String?
  remarks               String?

  customer Customer @relation(fields: [customer_id], references: [id])
  project  Project  @relation(fields: [project_id], references: [id])
  unit     Unit?    @relation(fields: [unit_id], references: [id])
  approver User?    @relation("QuotationApprover", fields: [approved_by], references: [id])
  creator  User     @relation("QuotationCreator", fields: [created_by], references: [id])

  contracts Contract[]

  @@index([customer_id])
  @@index([project_id])
  @@index([unit_id])
  @@index([approved_by])
  @@index([created_by])
  @@index([status])
}

model CommercialQuotation {
  id               String          @id @default(uuid())
  quotation_number String          @unique
  customer_id      String
  project_id       String
  items            Json            @default("[]")
  terms            String?
  conditions       String?
  total_amount     Float           @default(0)
  status           QuotationStatus @default(DRAFT)
  created_by       String
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  customer Customer @relation(fields: [customer_id], references: [id])
  project  Project  @relation(fields: [project_id], references: [id])
  creator  User     @relation("CommercialQuotationCreator", fields: [created_by], references: [id])

  @@index([customer_id])
  @@index([project_id])
  @@index([created_by])
  @@index([status])
}

model CommercialProposal {
  id              String         @id @default(uuid())
  proposal_number String         @unique
  customer_id     String
  project_id      String
  content         Json           @default("{}")
  status          ProposalStatus @default(DRAFT)
  created_by      String
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  customer Customer @relation(fields: [customer_id], references: [id])
  project  Project  @relation(fields: [project_id], references: [id])
  creator  User     @relation("CommercialProposalCreator", fields: [created_by], references: [id])

  @@index([customer_id])
  @@index([project_id])
  @@index([created_by])
  @@index([status])
}

// ─── Contracts Domain ─────────────────────────────────────────────────────────

model Contract {
  id              String         @id @default(uuid())
  contract_number String         @unique
  customer_id     String
  project_id      String
  unit_id         String?
  quotation_id    String?
  type            ContractType
  start_date      DateTime
  end_date        DateTime?
  value           Float          @default(0)
  monthly_rent    Float?
  deposit_amount  Float?
  terms           String?
  status          ContractStatus @default(DRAFT)
  approved_by     String?
  created_by      String
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  customer  Customer   @relation(fields: [customer_id], references: [id])
  project   Project    @relation(fields: [project_id], references: [id])
  unit      Unit?      @relation(fields: [unit_id], references: [id])
  quotation Quotation? @relation(fields: [quotation_id], references: [id])
  approver  User?      @relation("ContractApprover", fields: [approved_by], references: [id])
  creator   User       @relation("ContractCreator", fields: [created_by], references: [id])

  lease_agreements       LeaseAgreement[]
