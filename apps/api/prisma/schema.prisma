// ─── Finance / Accounting Domain ─────────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  COST_OF_SALES
  OPERATING_EXPENSE
  OTHER_INCOME
  OTHER_EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum CashFlowCategory {
  OPERATING
  INVESTING
  FINANCING
  NONE
}

enum AccountingPeriodStatus {
  OPEN
  SOFT_CLOSED
  HARD_CLOSED
}

enum JournalType {
  GENERAL
  CASH_RECEIPT
  CASH_PAYMENT
  PURCHASE
  SALES
  ADJUSTMENT
  REVERSING
  ACCRUAL
  DEPRECIATION
  CLOSING
}

enum JournalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  POSTED
  CANCELLED
}

model ChartOfAccount {
  id                  String           @id @default(cuid())
  account_code        String           @unique
  account_name_th     String
  account_name_en     String?
  account_type        AccountType
  level               Int              @default(3)
  parent_account_code String?
  parent              ChartOfAccount?  @relation("AccountHierarchy", fields: [parent_account_code], references: [account_code])
  children            ChartOfAccount[] @relation("AccountHierarchy")
  normal_balance      NormalBalance    @default(DEBIT)
  cash_flow_category  CashFlowCategory @default(NONE)
  vat_type            String           @default("NONE")
  tax_applicable      Boolean          @default(false)
  is_subledger        Boolean          @default(false)
  is_active           Boolean          @default(true)
  reporting_group     String?
  description         String?
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt

  journal_lines JournalEntryLine[]

  @@index([account_type])
  @@index([parent_account_code])
  @@index([is_active])
}

model AccountingPeriod {
  id        String                 @id @default(cuid())
  year      Int
  month     Int
  status    AccountingPeriodStatus @default(OPEN)
  closed_by String?
  closer    User?                  @relation("PeriodCloser", fields: [closed_by], references: [id])
  closed_at DateTime?
  created_at DateTime              @default(now())
  updated_at DateTime              @updatedAt

  @@unique([year, month])
  @@index([year])
  @@index([status])
}

model JournalEntry {
  id                 String        @id @default(cuid())
  journal_number     String        @unique
  journal_type       JournalType   @default(GENERAL)
  journal_date       DateTime
  posting_period     String
  reference_document String?
  narration          String?
  source_module      String?
  status             JournalStatus @default(DRAFT)
  total_debit        Decimal       @default(0) @db.Decimal(18, 2)
  total_credit       Decimal       @default(0) @db.Decimal(18, 2)
  prepared_by        String?
  preparer           User?         @relation("JEPreparer", fields: [prepared_by], references: [id])
  reviewed_by        String?
  reviewer           User?         @relation("JEReviewer", fields: [reviewed_by], references: [id])
  approved_by        String?
  approver           User?         @relation("JEApprover", fields: [approved_by], references: [id])
  posted_at          DateTime?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  lines JournalEntryLine[]

  @@index([journal_type])
  @@index([status])
  @@index([posting_period])
  @@index([journal_date])
}

model JournalEntryLine {
  id               String         @id @default(cuid())
  journal_entry_id String
  journal_entry    JournalEntry   @relation(fields: [journal_entry_id], references: [id], onDelete: Cascade)
  line_number      Int
  account_code     String
  account          ChartOfAccount @relation(fields: [account_code], references: [account_code])
  debit            Decimal        @default(0) @db.Decimal(18, 2)
  credit           Decimal        @default(0) @db.Decimal(18, 2)
  description      String?
  dimension_site   String?
  dimension_project String?
  dimension_dept   String?

  @@index([journal_entry_id])
  @@index([account_code])
}

// ─── Banking ─────────────────────────────────────────────────────────────────

enum BankAccountType {
  SAVINGS
  CURRENT
  FIXED_DEPOSIT
}

enum ReconciliationStatus {
  IN_PROGRESS
  BALANCED
  UNBALANCED
}

enum ChequeType {
  ISSUED
  RECEIVED
}

enum ChequeStatus {
  ISSUED
  CLEARED
  BOUNCED
  CANCELLED
  VOIDED
}

model BankAccount {
  id              String          @id @default(cuid())
  account_name    String
  account_number  String          @unique
  bank_name       String
  branch_name     String?
  account_type    BankAccountType @default(CURRENT)
  gl_account_code String?
  site_id         String?
  site            Project?        @relation("BankAccountSite", fields: [site_id], references: [id])
  currency        String          @default("THB")
  opening_balance Decimal         @default(0) @db.Decimal(18, 2)
  current_balance Decimal         @default(0) @db.Decimal(18, 2)
  is_active       Boolean         @default(true)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  reconciliations BankReconciliation[]
  cheques         ChequeRegister[]

  @@index([is_active])
}

model BankReconciliation {
  id                     String               @id @default(cuid())
  reconciliation_number  String               @unique
  bank_account_id        String
  bank_account           BankAccount          @relation(fields: [bank_account_id], references: [id])
  reconciliation_month   String
  bank_statement_balance Decimal              @db.Decimal(18, 2)
  book_balance           Decimal              @db.Decimal(18, 2)
  adjusted_bank_balance  Decimal?             @db.Decimal(18, 2)
  adjusted_book_balance  Decimal?             @db.Decimal(18, 2)
  difference             Decimal              @default(0) @db.Decimal(18, 2)
  status                 ReconciliationStatus @default(IN_PROGRESS)
  reconciled_by          String?
  reconciler             User?                @relation("ReconciliationReconciler", fields: [reconciled_by], references: [id])
  reconciled_at          DateTime?
  notes                  String?
  created_at             DateTime             @default(now())
  updated_at             DateTime             @updatedAt

  items BankReconciliationItem[]

  @@index([bank_account_id])
  @@index([status])
}

model BankReconciliationItem {
  id                String             @id @default(cuid())
  reconciliation_id String
  reconciliation    BankReconciliation @relation(fields: [reconciliation_id], references: [id], onDelete: Cascade)
  description       String
  amount            Decimal            @db.Decimal(18, 2)
  item_type         String
  is_bank_side      Boolean            @default(true)

  @@index([reconciliation_id])
}

model ChequeRegister {
  id                 String       @id @default(cuid())
  cheque_number      String
  cheque_type        ChequeType
  cheque_date        DateTime
  bank_account_id    String
  bank_account       BankAccount  @relation(fields: [bank_account_id], references: [id])
  amount             Decimal      @db.Decimal(18, 2)
  payee_name         String
  status             ChequeStatus @default(ISSUED)
  reference_document String?
  cleared_date       DateTime?
  bounced_date       DateTime?
  journal_entry_id   String?
  notes              String?
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt

  @@index([bank_account_id])
  @@index([status])
  @@index([cheque_type])
}

// ─── Tax & Compliance ────────────────────────────────────────────────────────

enum WhtDocumentType {
  PND1
  PND3
  PND53
}

enum WhtStatus {
  DRAFT
  ISSUED
  SUBMITTED
  CANCELLED
}

model WithholdingTaxRecord {
  id                 String          @id @default(cuid())
  wht_number         String          @unique
  document_type      WhtDocumentType
  fiscal_year        Int
  fiscal_month       Int
  vendor_id          String?
  vendor             Vendor?         @relation(fields: [vendor_id], references: [id])
  vendor_name        String
  tax_id             String?
  income_type        String?
  gross_amount       Decimal         @db.Decimal(18, 2)
  wht_rate           Decimal         @db.Decimal(5, 2)
  wht_amount         Decimal         @db.Decimal(18, 2)
  net_amount         Decimal         @db.Decimal(18, 2)
  payment_date       DateTime?
  certificate_issued Boolean         @default(false)
  certificate_date   DateTime?
  status             WhtStatus       @default(DRAFT)
  journal_entry_id   String?
  created_by         String?
  creator            User?           @relation("WHTCreator", fields: [created_by], references: [id])
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt

  @@index([document_type])
  @@index([fiscal_year, fiscal_month])
  @@index([status])
}

model VatTransaction {
  id                  String   @id @default(cuid())
  transaction_type    String
  document_number     String
  document_date       DateTime
  counterparty_name   String
  counterparty_tax_id String?
  net_amount          Decimal  @db.Decimal(18, 2)
  vat_amount          Decimal  @db.Decimal(18, 2)
  gross_amount        Decimal  @db.Decimal(18, 2)
  vat_rate            Decimal  @default(7) @db.Decimal(5, 2)
  source_module       String?
  source_document_id  String?
  period              String
  is_filed            Boolean  @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([transaction_type])
  @@index([period])
  @@index([is_filed])
}

// ─── AP Enhancements ─────────────────────────────────────────────────────────

enum APInvoiceStatus {
  AP_DRAFT
  AP_PENDING_APPROVAL
  AP_APPROVED
  AP_PARTIALLY_PAID
  AP_PAID
  AP_CANCELLED
}

enum PaymentVoucherStatus {
  PV_DRAFT
  PV_PENDING_APPROVAL
  PV_APPROVED
  PV_PAID
  PV_CANCELLED
}

model APInvoice {
  id                    String          @id @default(cuid())
  ap_invoice_number     String          @unique
  vendor_id             String
  vendor                Vendor          @relation(fields: [vendor_id], references: [id])
  vendor_invoice_number String?
  invoice_date          DateTime
  due_date              DateTime
  payment_terms         String?
  subtotal              Decimal         @db.Decimal(18, 2)
  vat_amount            Decimal         @default(0) @db.Decimal(18, 2)
  wht_amount            Decimal         @default(0) @db.Decimal(18, 2)
  total_amount          Decimal         @db.Decimal(18, 2)
  status                APInvoiceStatus @default(AP_DRAFT)
  matched_po_id         String?
  matched_grn_id        String?
  gl_account_code       String?
  journal_entry_id      String?
  items                 Json?
  notes                 String?
  created_by            String?
  creator               User?           @relation("APInvoiceCreator", fields: [created_by], references: [id])
  approved_by           String?
  approver              User?           @relation("APInvoiceApprover", fields: [approved_by], references: [id])
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  @@index([vendor_id])
  @@index([status])
  @@index([due_date])
}

model PaymentVoucher {
  id               String               @id @default(cuid())
  voucher_number   String               @unique
  vendor_id        String
  vendor           Vendor               @relation(fields: [vendor_id], references: [id])
  payment_date     DateTime
  total_amount     Decimal              @db.Decimal(18, 2)
  payment_method   String
  bank_account_id  String?
  cheque_number    String?
  status           PaymentVoucherStatus @default(PV_DRAFT)
  journal_entry_id String?
  ap_invoice_ids   Json?
  notes            String?
  created_by       String?
  creator          User?                @relation("PVCreator", fields: [created_by], references: [id])
  approved_by      String?
  approver         User?                @relation("PVApprover", fields: [approved_by], references: [id])
  created_at       DateTime             @default(now())
  updated_at       DateTime             @updatedAt

  @@index([vendor_id])
  @@index([status])
}

// ─── Fixed Asset Accounting ──────────────────────────────────────────────────

model DepreciationSchedule {
  id                     String   @id @default(cuid())
  asset_id               String
  asset                  Asset    @relation(fields: [asset_id], references: [id])
  period                 String
  depreciation_amount    Decimal  @db.Decimal(18, 2)
  accumulated_total      Decimal  @db.Decimal(18, 2)
  net_book_value         Decimal  @db.Decimal(18, 2)
  journal_entry_id       String?
  is_posted              Boolean  @default(false)
  created_at             DateTime @default(now())

  @@index([asset_id])
  @@index([period])
}

model AssetDisposal {
  id               String   @id @default(cuid())
  disposal_number  String   @unique
  asset_id         String
  asset            Asset    @relation(fields: [asset_id], references: [id])
  disposal_type    String
  disposal_date    DateTime
  disposal_amount  Decimal  @default(0) @db.Decimal(18, 2)
  gain_loss        Decimal  @default(0) @db.Decimal(18, 2)
  buyer_info       String?
  journal_entry_id String?
  notes            String?
  created_by       String?
  creator          User?    @relation("DisposalCreator", fields: [created_by], references: [id])
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([asset_id])
}

model AssetTransfer {
  id               String   @id @default(cuid())
  transfer_number  String   @unique
  asset_id         String
  asset            Asset    @relation(fields: [asset_id], references: [id])
  from_site_id     String?
  to_site_id       String?
  transfer_date    DateTime
  reason           String?
  journal_entry_id String?
  created_by       String?
  creator          User?    @relation("TransferCreator", fields: [created_by], references: [id])
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([asset_id])
}
