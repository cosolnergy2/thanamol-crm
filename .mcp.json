{
  "mcpServers": {
    "automated-test": {
      "command": "bun",
      "args": [
        "run",
        "mcp/browser/src/index.ts"
      ],
      "env": {
        "HEADLESS": "false",
        "CHROME_DATA_DIR": "mcp/browser/chrome-data",
        "VIEWPORT_WIDTH": "1920",
        "VIEWPORT_HEIGHT": "1080",
        "REPORT_DIR": "mcp/browser/reports"
      }
    }
  }
}
